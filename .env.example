# Open-Merge Broker configuration
# Copy to .env and fill in values. Real env vars override these.

DATABASE_URL=
BROKER_AUTH_SECRET=

# Optional
# BROKER_LISTEN_ADDR=:8080
# BROKER_SIGNAL_TTL=168h
# BROKER_RATE_LIMIT=60
# BROKER_LOG_LEVEL=info
# BROKER_SHUTDOWN_TIMEOUT=30s
BROKER_MATCH_INTERVAL=6h
BROKER_CLEANUP_INTERVAL=1h

# Telegram Bot (optional — leave empty to disable introductions)
# TELEGRAM_BOT_TOKEN=
